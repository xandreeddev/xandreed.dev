---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Toc from '../../components/Toc.astro';
import { getPosts, isoDate, readingTime, type Post } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: { post, newer: posts[i - 1] ?? null, older: posts[i + 1] ?? null },
  }));
}

interface Props {
  post: Post;
  newer: Post | null;
  older: Post | null;
}

const { post, newer, older } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? '');
---

<Base title={`${post.data.title} — xandreed`} description={post.data.description} ogType="article">
  <div class="container">
    <article class="post-wrap">
      <header class="post-header">
        <p class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{isoDate(post.data.pubDate)}</time>
          <span class="sep" aria-hidden="true">·</span>
          <span>{minutes} min read</span>
          {post.data.tags.length > 0 && <span class="sep" aria-hidden="true">·</span>}
          {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
          {post.data.draft && <span class="draft-badge">draft</span>}
        </p>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
      </header>
      <Toc headings={headings} />
      <div class="prose">
        <Content />
      </div>
      <footer class="post-footer">
        <p class="cta">
          I build efferent in public — follow along on <a href="https://x.com/xandreeddev">X</a> or
          read the source on <a href="https://github.com/xandreeddev/agent">GitHub</a>.
        </p>
        <nav class="post-nav" aria-label="Adjacent posts">
          <span>
            {
              older && (
                <a href={`/posts/${older.id}/`}>
                  <span class="dir">← older</span>
                  <span class="t">{older.data.title}</span>
                </a>
              )
            }
          </span>
          <span class="next">
            {
              newer && (
                <a href={`/posts/${newer.id}/`}>
                  <span class="dir">newer →</span>
                  <span class="t">{newer.data.title}</span>
                </a>
              )
            }
          </span>
        </nav>
      </footer>
    </article>
  </div>
</Base>
