---
import type { SeriesPart } from '../utils/posts';

interface Props {
  name: string;
  slug: string;
  parts: SeriesPart[];
}

const { name, slug, parts } = Astro.props;
const rank = parts.findIndex((p) => p.current) + 1;
---

{
  parts.length >= 2 && (
    <aside class="series-banner" aria-label={`Series: ${name}`}>
      <p class="series-eyebrow">
        <a href={`/series/${slug}/`}>{name}</a> · Part {rank} of {parts.length}
      </p>
      <ol class="series-list">
        {parts.map((p) => (
          <li class:list={['series-item', { current: p.current }]}>
            {p.current ? (
              <span>
                {p.title}
                {p.draft && <span class="draft-badge">draft</span>}
              </span>
            ) : (
              <a href={p.href}>
                {p.title}
                {p.draft && <span class="draft-badge">draft</span>}
              </a>
            )}
          </li>
        ))}
      </ol>
    </aside>
  )
}
